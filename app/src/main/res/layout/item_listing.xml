<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="3dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp">

        <ImageView
            android:id="@+id/ivListingImage"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:background="@drawable/round_cor"
            android:backgroundTint="#F0E0E0"
            android:scaleType="centerCrop"
            android:src="@drawable/buy_icon" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvListingTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#111111"
                android:textSize="15sp"
                android:textStyle="bold"
                android:text="Title" />

            <TextView
                android:id="@+id/tvListingDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:maxLines="2"
                android:ellipsize="end"
                android:textColor="#666666"
                android:textSize="13sp"
                android:text="Description" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvListingPrice"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="#811112"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:text="₱0.00" />

                <TextView
                    android:id="@+id/tvListingType"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/round_cor"
                    android:backgroundTint="#811112"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="2dp"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"
                    android:text="SELL" />

                <TextView
                    android:id="@+id/tvListingStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/round_cor"
                    android:backgroundTint="#4CAF50"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="2dp"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"
                    android:text="ACTIVE" />

            </LinearLayout>

            <TextView
                android:id="@+id/tvSellerName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="#999999"
                android:textSize="11sp"
                android:text="by Seller" />

        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
